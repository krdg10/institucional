---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const whatsappLink = "https://wa.me/5541999999999";
const instagramLink = "https://instagram.com/debora.fernandes.psi";
const email = "deborfernandes.psi@gmail.com";
const phoneDisplay = "(43) 99126-4083";
---

<Layout>
	<script>
		const btn = document.getElementById("whatsappButton");

		if (btn) {
			window.addEventListener("scroll", () => {
				if (window.scrollY > 120) {
					btn.classList.add("visible");
				} else {
					btn.classList.remove("visible");
				}
			});
		}
	</script>

	<main>
		<section class="panel panel--hero" id="inicio">
			<div class="panel__inner panel__inner--centered">
				<p class="hero__symbol">Ψ</p>
				<h1>DÉBORA FERNANDES</h1>
				<p class="hero__meta">Psicóloga Clínica</p>
				<p class="hero__meta">CRP-08/38319</p>
				<a
					class="btn btn--light"
					href={whatsappLink}
					target="_blank"
					rel="noreferrer">Agende sua sessão</a
				>
				<p class="hero__tagline">
					Terapia on-line com acolhimento, ética e compromisso com sua
					história.
				</p>
			</div>
		</section>

		<section class="panel panel--purple">
			<div class="panel__inner panel__split">
				<div
					class="photo-placeholder"
					role="img"
					aria-label="Foto de apresentação da psicóloga"
				>
				</div>
				<div class="panel__content">
					<h2>Olá, meu nome é Débora Fernandes</h2>
					<p>
						Sou psicóloga clínica - CRP 08/38319. Meu trabalho é
						oferecer um ambiente seguro, ético e respeitoso para que
						você possa se aproximar de si mesma com mais clareza.
					</p>
					<p>
						Sou formada em Psicologia pela PUCPR e especialista em
						terapias comportamentais contextuais, com atuação
						orientada pela Análise do Comportamento.
					</p>
				</div>
			</div>
		</section>

		<section class="panel panel--white">
			<div class="panel__inner panel__inner--narrow">
				<h2>Sobre a psicoterapia</h2>
				<p class="intro-text">
					A psicoterapia é um processo de acompanhamento psicológico
					que ajuda você a compreender melhor seus pensamentos,
					emoções e comportamentos. Ao longo das sessões, investigamos
					juntos:
				</p>
				<div class="cards">
					<article class="card">
						Padrões que se repetem em relacionamentos e situações da
						vida.
					</article>
					<article class="card">
						Formas de lidar com ansiedade, insegurança, conflitos e
						mudanças.
					</article>
					<article class="card">
						Dificuldades emocionais e momentos de sofrimento.
					</article>
					<article class="card">
						Possibilidades de construir uma vida mais alinhada ao
						que é importante para você.
					</article>
				</div>
			</div>
		</section>

		<section class="panel panel--purple panel--contact">
			<div
				class="panel__inner panel__inner--narrow panel__inner--centered"
			>
				<h2>Como funcionam os atendimentos?</h2>
				<p>
					As sessões duram cerca de 50 minutos, acontecem online por
					videochamada e, geralmente, uma vez por semana. Todo o
					atendimento é feito em um ambiente seguro, ético e
					confortável para você.
				</p>
				<p class="contact-note">
					A terapia não é apenas um espaço de “resolver problemas”,
					mas também um lugar de descoberta, reflexão e
					desenvolvimento de novas formas de viver.
				</p>
				<a
					class="btn btn--dark"
					href={whatsappLink}
					target="_blank"
					rel="noreferrer">Entre em contato comigo!</a
				>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="site-footer__topbar"></div>

		<div class="site-footer__inner">
			<div class="site-footer__brand">
				<div class="site-footer__logo">Ψ</div>

				<div class="site-footer__brand-text">
					<p class="site-footer__name">DÉBORA FERNANDES</p>
					<p class="site-footer__role">Psicóloga Clínica</p>
					<p class="site-footer__crp">CRP-08/38319</p>
				</div>
			</div>

			<div class="site-footer__contact">
				<a
					class="site-footer__item"
					href={whatsappLink}
					target="_blank"
					rel="noreferrer"
				>
					<span class="site-footer__icon">
						<Icon name="mdi:whatsapp" size="22" />
					</span>
					<span>{phoneDisplay}</span>
				</a>

				<a class="site-footer__item" href={`mailto:${email}`}>
					<span class="site-footer__icon">
						<Icon name="mdi:email-outline" size="22" />
					</span>
					<span>{email}</span>
				</a>

				<a
					class="site-footer__item"
					href={instagramLink}
					target="_blank"
					rel="noreferrer"
				>
					<span class="site-footer__icon">
						<Icon name="mdi:instagram" size="22" />
					</span>
					<span>@deborfernandes.psi</span>
				</a>
			</div>
		</div>
	</footer>

	<a
		class="whatsapp-float"
		id="whatsappButton"
		href={whatsappLink}
		target="_blank"
		rel="noreferrer"
		aria-label="Falar no WhatsApp"
	>
		<Icon name="mdi:whatsapp" size="28" />
	</a>
</Layout>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(body) {
		margin: 0;
		font-family: "Cormorant Garamond", Georgia, serif;
		color: #6c456b;
		background: #fff;
	}

	main {
		width: 100%;
	}

	.panel {
		width: 100%;
		padding: clamp(2rem, 4vw, 4rem) 0;
	}

	.panel__inner {
		width: min(1220px, 92vw);
		margin: 0 auto;
		position: relative;
	}

	.panel__inner--narrow {
		width: min(1080px, 90vw);
	}

	.panel__inner--centered {
		text-align: center;
	}

	.panel--hero {
		min-height: 100svh;
		display: grid;
		align-items: center;
		position: relative;
		background-color: #cfcbc0;
		overflow: hidden;
	}

	.panel--hero::before {
		content: "";
		position: absolute;
		inset: 0;
		background-image: url("/backgroundHero.png");
		background-repeat: repeat;
		background-size: 520px;
		background-position: center;
		opacity: 1;
		z-index: 0;
	}

	.panel--hero::after {
		content: "";
		position: absolute;
		inset: 0;
		background: rgba(255, 255, 255, 0.72);
		z-index: 1;
	}

	.panel--hero .panel__inner {
		position: relative;
		z-index: 2;
	}

	.panel--purple {
		background: #c6b0d7;
		color: #f7f0ff;
	}

	.panel--white {
		background: #f4f1eb;
		color: #6f4970;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.2rem, 6vw, 5rem);
		letter-spacing: 0.04em;
		color: #cfb8ea;
	}

	h2 {
		margin: 0 0 1rem;
		font-size: clamp(2rem, 5vw, 4rem);
		line-height: 1.1;
	}

	p {
		margin: 0;
		font-size: clamp(1.2rem, 2.4vw, 1.9rem);
		line-height: 1.35;
	}

	.hero__symbol {
		font-size: clamp(3.2rem, 9vw, 7rem);
		margin: 0;
		color: #cfb8ea;
		text-shadow: 0 5px 14px rgba(122, 90, 136, 0.25);
	}

	.hero__meta {
		color: #dfcfee;
	}

	.hero__tagline {
		margin: 1.8rem auto 0;
		max-width: 980px;
		font-size: clamp(1rem, 2.5vw, 2.1rem);
		color: #744d75;
	}

	.panel__split {
		display: grid;
		grid-template-columns: minmax(260px, 42%) minmax(320px, 1fr);
		align-items: stretch;
	}

	.photo-placeholder {
		min-height: 620px;
		background-image: url("/me.jpg");
		background-size: cover;
		background-position: center;
	}

	.panel__content {
		padding: clamp(2rem, 5vw, 5rem);
		display: grid;
		gap: 1.2rem;
		position: relative;
	}

	.panel__content p {
		font-family: "Inter", "Segoe UI", sans-serif;
		font-size: clamp(1.1rem, 2vw, 1.95rem);
		line-height: 1.5;
	}

	.intro-text {
		font-size: clamp(1.4rem, 2.3vw, 2.2rem);
		max-width: 940px;
	}

	.cards {
		margin-top: 1.4rem;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}

	.card {
		background: #c6b0d7;
		color: #f7f0ff;
		border-radius: 28px;
		padding: 1.6rem;
		font-size: clamp(1.2rem, 1.8vw, 1.9rem);
		text-align: center;
		min-height: 260px;
		display: grid;
		place-items: center;
	}

	.panel--contact h2,
	.panel--contact p {
		color: #6f476f;
	}

	.panel--contact .contact-note {
		color: #fff5ff;
		max-width: 980px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		padding: 0.9rem 2rem;
		border-radius: 999px;
		font-family: "Inter", "Segoe UI", sans-serif;
		font-weight: 600;
		font-size: clamp(1rem, 1.4vw, 1.25rem);
	}

	.btn--light {
		margin-top: 1rem;
		background: #c3a3df;
		color: #fff;
	}

	.btn--outline {
		width: fit-content;
		border: 1px solid #fff5ff;
		color: #fff;
	}

	.btn--dark {
		margin-top: 1.5rem;
		background: #7e527d;
		color: #fff;
	}

	.flower {
		display: inline-block;
		width: 130px;
		height: 130px;
		position: relative;
	}

	.flower::before,
	.flower::after {
		content: "";
		position: absolute;
		inset: 0;
		margin: auto;
		width: 40px;
		height: 40px;
		border-radius: 999px;
		background: currentColor;
		box-shadow:
			0 -44px 0 currentColor,
			38px -22px 0 currentColor,
			38px 22px 0 currentColor,
			0 44px 0 currentColor,
			-38px 22px 0 currentColor,
			-38px -22px 0 currentColor;
	}

	.flower--dark {
		color: #7d4f7a;
		margin-top: 1rem;
	}

	.flower--top {
		color: #7d4f7a;
		position: absolute;
		top: -86px;
		left: -72px;
		transform: scale(1.08);
	}

	.flower--side {
		color: #7d4f7a;
		position: absolute;
		right: -80px;
		top: 36%;
	}

	.panel--contact .panel__inner {
		display: grid;
		gap: 1.2rem;
		justify-items: center;
	}

	.site-footer {
		background: #f2efe8;
	}

	.site-footer__topbar {
		height: 14px;
		background: #c6b0d7;
	}

	.site-footer__inner {
		width: min(1220px, 92vw);
		margin: 0 auto;
		padding: 3.25rem 0 3rem;
		display: grid;
		grid-template-columns: minmax(280px, 1fr) auto;
		gap: 2.5rem;
		align-items: center;
	}

	.site-footer__brand {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		color: #ceb9e5;
	}

	.site-footer__logo {
		font-size: clamp(8rem, 6vw, 5.8rem);
		line-height: 1;
		text-shadow: 0 5px 14px rgba(122, 90, 136, 0.25);
		flex-shrink: 0;
	}

	.site-footer__brand-text {
		display: grid;
		gap: 0.3rem;
		padding-top: 0;
	}

	.site-footer__name {
		font-size: clamp(1.8rem, 3vw, 3rem);
		line-height: 1;
		letter-spacing: 0.03em;
		font-weight: 700;
		color: #ceb9e5;
	}

	.site-footer__role,
	.site-footer__crp {
		font-family: "Inter", "Segoe UI", sans-serif;
		font-size: 1.25rem;
		line-height: 1.45;
		color: #b9a3d2;
	}

	.site-footer__contact {
		display: grid;
		gap: 1.15rem;
		justify-items: start;
	}

	.site-footer__item {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		text-decoration: none;
		font-family: "Inter", "Segoe UI", sans-serif;
		font-size: 1.2rem;
		color: #c6b0d7;
		transition: opacity 0.2s ease;
	}

	.site-footer__item:hover {
		opacity: 0.78;
	}

	.site-footer__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: #c6b0d7;
		flex-shrink: 0;
		transform: scale(1.15);
	}

	.whatsapp-float {
		position: fixed;
		right: 1.4rem;
		bottom: 1.4rem;
		width: 64px;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: #7d4f7a;
		color: white;
		box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
		z-index: 1000;
		text-decoration: none;
		opacity: 0;
		transform: translateY(20px);
		pointer-events: none;
		transition:
			opacity 0.35s ease,
			transform 0.35s ease,
			box-shadow 0.2s ease;
	}

	.whatsapp-float.visible {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}

	.whatsapp-float:hover {
		transform: translateY(-3px);
		box-shadow: 0 16px 34px rgba(0, 0, 0, 0.22);
	}

	@media (max-width: 1050px) {
		.cards {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.flower--side {
			display: none;
		}
	}

	@media (max-width: 840px) {
		.panel__split {
			grid-template-columns: 1fr;
		}

		.photo-placeholder {
			min-height: 380px;
		}

		.flower--top {
			display: none;
		}

		.site-footer__inner {
			grid-template-columns: 1fr;
			gap: 2rem;
			padding: 2.5rem 0 2.4rem;
		}

		.site-footer__contact {
			justify-items: start;
		}
	}

	@media (max-width: 640px) {
		.cards {
			grid-template-columns: 1fr;
		}

		.panel--hero {
			min-height: 88svh;
		}

		p {
			font-size: 1.15rem;
		}

		.site-footer__brand {
			align-items: center;
		}

		.site-footer__name {
			font-size: 1.6rem;
		}

		.site-footer__role,
		.site-footer__crp,
		.site-footer__item {
			font-size: 1rem;
		}
	}
</style>
