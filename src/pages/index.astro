---
import Layout from "../layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const contatos = {
	whatsappLink: "https://wa.me/5543991264083",
	instagramLink: "https://instagram.com/deborafernandes.psi",
	email: "deborafernandes.psi@gmail.com",
	telefoneExibicao: "(43) 99126-4083",
	instagramUsuario: "@deborafernandes.psi",
};

const apresentacao = {
	nome: "DÉBORA FERNANDES",
	profissao: "Psicóloga Clínica",
	crp: "CRP-08/38319",
	chamada:
		"Terapia on-line com acolhimento, ética e compromisso com sua história.",
	tituloSecao: "Débora Fernandes",
	textos: [
		"Sou psicóloga clínica - CRP 08/38319. Meu trabalho é oferecer um ambiente seguro, ético e respeitoso para que você possa se aproximar de si mesma com mais clareza.",
		"Sou formada em Psicologia pela PUCPR e especialista em terapias comportamentais contextuais, com atuação orientada pela Análise do Comportamento.",
	],
};

const topicosPsicoterapia = [
	"Padrões que se repetem em relacionamentos e situações da vida.",
	"Formas de lidar com ansiedade, insegurança, conflitos e mudanças.",
	"Dificuldades emocionais e momentos de sofrimento.",
	"Possibilidades de construir uma vida mais alinhada ao que é importante para você.",
];

const postsInstagram = [
	{
		imagem: "/post_1.jpg",
		link: "https://www.instagram.com/p/DV1WNDWGhAG",
		alt: "Post do Instagram da Débora Fernandes sobre sua relação com a psicologia.",
	},
	{
		imagem: "/post_2.jpg",
		link: "https://www.instagram.com/p/DVwEW9fFhAP",
		alt: "Post do Instagram da Débora Fernandes sobre relação com o trabalho.",
	},
	{
		imagem: "/post_3.jpg",
		link: "https://www.instagram.com/p/DUqt-O1mvPm",
		alt: "Post do Instagram da Débora Fernandes sobre a série Pluribus.",
	},
];
---

<Layout>
	<script>
		const obterElementosRevelacao = (): NodeListOf<HTMLElement> =>
			document.querySelectorAll(".reveal-up");

		const elementoJaVisivelNaTela = (
			elemento: HTMLElement,
			fator = 0.95,
		): boolean => {
			const retangulo = elemento.getBoundingClientRect();

			return (
				retangulo.top < window.innerHeight * fator &&
				retangulo.bottom > 0
			);
		};

		const inicializarBotaoWhatsapp = () => {
			const botaoWhatsapp = document.getElementById("whatsappButton");
			if (!botaoWhatsapp) return;

			const atualizarVisibilidadeBotao = () => {
				botaoWhatsapp.classList.toggle("visible", window.scrollY > 120);
			};

			atualizarVisibilidadeBotao();

			window.addEventListener("scroll", atualizarVisibilidadeBotao, {
				passive: true,
			});
		};

		const inicializarAnimacaoRevelacao = () => {
			const elementos = obterElementosRevelacao();
			if (!elementos.length) return;

			const observador = new IntersectionObserver(
				(entradas, obs) => {
					entradas.forEach((entrada) => {
						if (!entrada.isIntersecting) return;

						entrada.target.classList.add("is-visible");
						obs.unobserve(entrada.target);
					});
				},
				{
					threshold: 0.06,
					rootMargin: "0px 0px -6% 0px",
				},
			);

			elementos.forEach((elemento) => {
				if (elementoJaVisivelNaTela(elemento)) {
					elemento.classList.add("is-visible");
					return;
				}

				observador.observe(elemento);
			});

			window.addEventListener(
				"load",
				() => {
					obterElementosRevelacao().forEach((elemento) => {
						if (elementoJaVisivelNaTela(elemento, 1)) {
							elemento.classList.add("is-visible");
						}
					});
				},
				{ once: true },
			);
		};

		const inicializarPagina = () => {
			inicializarBotaoWhatsapp();
			inicializarAnimacaoRevelacao();
		};

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", inicializarPagina, {
				once: true,
			});
		} else {
			inicializarPagina();
		}
	</script>

	<main>
		<section class="panel panel--hero" id="inicio">
			<div class="panel__inner panel__inner--centered">
				<p class="hero__symbol reveal-up reveal-delay-1">Ψ</p>

				<h1 class="reveal-up reveal-delay-2 cor-hero title-seasons">
					{apresentacao.nome}
				</h1>

				<p class="hero__meta reveal-up reveal-delay-3 font-livvic">
					{apresentacao.profissao}
				</p>

				<p class="hero__meta reveal-up reveal-delay-3 font-livvic">
					{apresentacao.crp}
				</p>

				<a
					class="btn btn--light reveal-up reveal-delay-4 font-seasons"
					href={contatos.whatsappLink}
					target="_blank"
					rel="noopener noreferrer"
				>
					Agende sua sessão
				</a>

				<p class="hero__tagline reveal-up reveal-delay-5">
					{apresentacao.chamada}
				</p>
			</div>
		</section>

		<section class="panel panel--purple">
			<div class="panel__inner panel__split">
				<div
					class="photo-placeholder reveal-up reveal-delay-1"
					role="img"
					aria-label="Foto de apresentação da psicóloga"
				>
				</div>

				<div class="panel__content">
					<p class="reveal-up reveal-delay-1">Olá, meu nome é</p>

					<h1 class="reveal-up reveal-delay-1">
						{apresentacao.tituloSecao}
					</h1>

					{
						apresentacao.textos.map((texto, index) => (
							<p
								class={`reveal-up reveal-delay-${index + 2} font-livvic text-align-justify`}
							>
								{texto}
							</p>
						))
					}
				</div>
			</div>
		</section>

		<section class="panel panel--white">
			<div
				class="panel__inner panel__inner--narrow panel__inner--centered"
			>
				<h2 class="reveal-up reveal-delay-1">Sobre a psicoterapia</h2>

				<p class="intro-text reveal-up reveal-delay-2">
					A psicoterapia é um processo de acompanhamento psicológico
					que ajuda você a compreender melhor seus pensamentos,
					emoções e comportamentos. Ao longo das sessões, investigamos
					juntos:
				</p>

				<div class="cards">
					{
						topicosPsicoterapia.map((topico, index) => (
							<article
								class={`card reveal-up reveal-delay-${index + 1}`}
							>
								{topico}
							</article>
						))
					}
				</div>
			</div>
		</section>

		<section class="panel panel--purple panel--contact">
			<div
				class="panel__inner panel__inner--narrow panel__inner--centered"
			>
				<h2 class="reveal-up reveal-delay-1">
					Como funcionam os atendimentos?
				</h2>

				<p class="reveal-up reveal-delay-2">
					As sessões duram cerca de 50 minutos, acontecem online por
					videochamada e, geralmente, uma vez por semana. Todo o
					atendimento é feito em um ambiente seguro, ético e
					confortável para você.
				</p>

				<p class="contact-note reveal-up reveal-delay-3">
					A terapia não é apenas um espaço de “resolver problemas”,
					mas também um lugar de descoberta, reflexão e
					desenvolvimento de novas formas de viver.
				</p>

				<a
					class="btn btn-big btn--dark reveal-up reveal-delay-4 font-seasons"
					href={contatos.whatsappLink}
					target="_blank"
					rel="noopener noreferrer"
				>
					Entre em contato comigo!
				</a>
			</div>
		</section>

		<section class="panel panel--social">
			<div
				class="panel__inner panel__inner--narrow panel__inner--centered"
			>
				<div
					class="social__divider reveal-up reveal-delay-1"
					aria-hidden="true"
				>
					<span class="social__divider-line"></span>
					<span class="social__divider-icon">
						<Icon name="mdi:instagram" size="18" />
					</span>
					<span class="social__divider-line"></span>
				</div>

				<h2 class="social__title reveal-up reveal-delay-2">
					Acompanhe-me nas redes sociais
				</h2>

				<a
					class="social__icon-link reveal-up reveal-delay-3"
					href={contatos.instagramLink}
					target="_blank"
					rel="noopener noreferrer"
					aria-label="Abrir Instagram"
				>
					<span class="social__icon-circle">
						<Icon name="mdi:instagram" size="28" />
					</span>
				</a>

				<div class="social__grid">
					{
						postsInstagram.map((post, index) => (
							<a
								class={`social__card reveal-up reveal-delay-${index + 1}`}
								href={post.link}
								target="_blank"
								rel="noopener noreferrer"
								aria-label={post.alt}
							>
								<img
									class="social__image"
									src={post.imagem}
									alt={post.alt}
									loading="lazy"
								/>
							</a>
						))
					}
				</div>
			</div>
		</section>
	</main>

	<footer class="site-footer">
		<div class="site-footer__topbar"></div>

		<div class="site-footer__inner">
			<div class="site-footer__brand reveal-up reveal-delay-1">
				<div class="site-footer__logo">Ψ</div>

				<div class="site-footer__brand-text">
					<p class="site-footer__name">{apresentacao.nome}</p>
					<p class="site-footer__role">{apresentacao.profissao}</p>
					<p class="site-footer__crp">{apresentacao.crp}</p>
				</div>
			</div>

			<div class="site-footer__contact reveal-up reveal-delay-2">
				<a
					class="site-footer__item"
					href={contatos.whatsappLink}
					target="_blank"
					rel="noopener noreferrer"
				>
					<span class="site-footer__icon">
						<Icon name="mdi:whatsapp" size="22" />
					</span>
					<span>{contatos.telefoneExibicao}</span>
				</a>

				<a class="site-footer__item" href={`mailto:${contatos.email}`}>
					<span class="site-footer__icon">
						<Icon name="mdi:email-outline" size="22" />
					</span>
					<span>{contatos.email}</span>
				</a>

				<a
					class="site-footer__item"
					href={contatos.instagramLink}
					target="_blank"
					rel="noopener noreferrer"
				>
					<span class="site-footer__icon">
						<Icon name="mdi:instagram" size="22" />
					</span>
					<span>{contatos.instagramUsuario}</span>
				</a>
			</div>
		</div>
	</footer>

	<a
		class="whatsapp-float"
		id="whatsappButton"
		href={contatos.whatsappLink}
		target="_blank"
		rel="noopener noreferrer"
		aria-label="Falar no WhatsApp"
	>
		<Icon name="mdi:whatsapp" size="28" />
	</a>
</Layout>

<style>
	@font-face {
		font-family: "The Seasons";
		src: url("/fonts/The Seasons.ttf") format("truetype");
		font-weight: 400;
		font-style: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "Livvic";
		src: url("/fonts/Livvic.ttf") format("truetype");
		font-weight: 100 900;
		font-style: normal;
		font-display: swap;
	}

	:root {
		--cor-lilas-principal: #c6b0d7;
		--cor-lilas-escuro: #7d4f7a;
		--cor-lilas-texto: #6f4970;
		--cor-lilas-claro: #cfb8ea;
		--cor-lilas-footer: #ceb9e5;
		--cor-lilas-footer-secundaria: #b9a3d2;
		--cor-fundo-claro: #f4f1eb;
		--cor-fundo-footer: #f2efe8;
		--cor-branco-suave: #f7f0ff;
		--cor-hero-fundo: #cfcbc0;
		--cor-sombra: rgba(122, 90, 136, 0.25);
		--cor-sombra-card: rgba(108, 69, 107, 0.08);
		--fonte-titulo: "The Seasons", Georgia, serif;
		--fonte-texto: "Livvic", "Segoe UI", sans-serif;
		--fonte-ui: "Inter", "Segoe UI", sans-serif;
	}

	:global(*) {
		box-sizing: border-box;
	}

	:global(body) {
		margin: 0;
		font-family: var(--fonte-titulo);
		color: #6c456b;
		background: #fff;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	main {
		width: 100%;
	}

	.font-seasons {
		font-family: var(--fonte-titulo) !important;
	}

	.font-livvic {
		font-family: var(--fonte-texto) !important;
	}

	.text-align-justify,
	.text-aling-justify {
		text-align: justify;
	}

	.cor-hero {
		color: var(--cor-lilas-claro);
	}

	.title-seasons {
		font-family: var(--fonte-titulo);
		color: #cbb6ea;
		letter-spacing: 0.05em;
	}

	.panel {
		width: 100%;
		padding: clamp(2rem, 4vw, 4rem) 0;
	}

	.panel__inner {
		width: min(1220px, 92vw);
		margin: 0 auto;
		position: relative;
	}

	.panel__inner--narrow {
		width: min(1080px, 90vw);
	}

	.panel__inner--centered {
		text-align: center;
	}

	.panel--hero {
		min-height: 100svh;
		display: grid;
		align-items: center;
		position: relative;
		background-color: var(--cor-hero-fundo);
		overflow: hidden;
	}

	.panel--hero::before {
		content: "";
		position: absolute;
		inset: 0;
		background-image: url("/backgroundHero.png");
		background-repeat: repeat;
		background-size: 520px;
		background-position: center;
		filter: brightness(1.02) contrast(0.94);
		z-index: 0;
	}

	.panel--hero::after {
		content: "";
		position: absolute;
		inset: 0;
		background: rgba(255, 255, 255, 0.85);
		z-index: 1;
	}

	.panel--hero .panel__inner {
		position: relative;
		z-index: 2;
	}

	.panel--purple {
		background: var(--cor-lilas-principal);
		color: var(--cor-branco-suave);
	}

	.panel--white,
	.panel--social {
		background: var(--cor-fundo-claro);
		color: var(--cor-lilas-texto);
	}

	.panel--contact h2,
	.panel--contact p {
		color: #6f476f;
	}

	.panel--contact .contact-note {
		color: #fff5ff;
		max-width: 980px;
	}

	.panel--contact .panel__inner {
		display: grid;
		gap: 1.2rem;
		justify-items: center;
	}

	h1 {
		margin: 0;
		font-size: clamp(2.2rem, 6vw, 5rem);
		letter-spacing: 0.04em;
	}

	h2 {
		margin: 0 0 1rem;
		font-size: clamp(2rem, 5vw, 4rem);
		line-height: 1.1;
	}

	p {
		margin: 0;
		font-size: clamp(1.2rem, 2.4vw, 1.9rem);
		line-height: 1.35;
	}

	.hero__symbol {
		font-size: clamp(3.2rem, 9vw, 7rem);
		margin: 0;
		color: var(--cor-lilas-claro);
		text-shadow: 0 5px 14px var(--cor-sombra);
	}

	.hero__meta,
	.hero__tagline {
		color: var(--cor-lilas-claro);
	}

	.hero__tagline {
		margin: 1.8rem auto 0;
		max-width: 980px;
		font-size: clamp(1rem, 2.5vw, 2.1rem);
	}

	.panel__split {
		display: grid;
		grid-template-columns: minmax(260px, 42%) minmax(320px, 1fr);
		align-items: stretch;
	}

	.photo-placeholder {
		min-height: 620px;
		background-image: url("/me.jpg");
		background-size: cover;
		background-position: center;
	}

	.panel__content {
		padding: clamp(2rem, 5vw, 5rem);
		display: grid;
		gap: 1.2rem;
		position: relative;
	}

	.panel__content p {
		font-family: var(--fonte-ui);
		font-size: clamp(1.1rem, 2vw, 1.95rem);
		line-height: 1.5;
	}

	.intro-text {
		font-size: clamp(1.4rem, 2.3vw, 2.2rem);
		max-width: 940px;
	}

	.cards {
		margin-top: 1.4rem;
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}

	.card {
		background: var(--cor-lilas-principal);
		color: var(--cor-branco-suave);
		border-radius: 28px;
		padding: 1.6rem;
		font-size: clamp(1.2rem, 1.8vw, 1.9rem);
		text-align: center;
		min-height: 260px;
		display: grid;
		place-items: center;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.9rem 2rem;
		border-radius: 999px;
		font-family: var(--fonte-ui);
		font-weight: 600;
		font-size: clamp(1rem, 1.4vw, 1.25rem);
	}

	.btn--light {
		margin-top: 1rem;
		background: #c3a3df;
		color: #fff;
	}

	.btn--dark {
		margin-top: 1.5rem;
		background: #7e527d;
		color: #fff;
	}

	.btn-big {
		padding: 2rem 3rem !important;
		font-size: clamp(1.25rem, 1.4vw, 1.5rem);
	}

	.site-footer {
		background: var(--cor-fundo-footer);
	}

	.site-footer__topbar {
		height: 14px;
		background: var(--cor-fundo-claro);
	}

	.site-footer__inner {
		width: min(1220px, 92vw);
		margin: 0 auto;
		padding: 3.25rem 0 3rem;
		display: grid;
		grid-template-columns: minmax(280px, 1fr) auto;
		gap: 2.5rem;
		align-items: center;
	}

	.site-footer__brand {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		color: var(--cor-lilas-footer);
	}

	.site-footer__logo {
		font-size: clamp(8rem, 6vw, 5.8rem);
		line-height: 1;
		text-shadow: 0 5px 14px var(--cor-sombra);
		flex-shrink: 0;
	}

	.site-footer__brand-text {
		display: grid;
		gap: 0.3rem;
		padding-top: 0;
	}

	.site-footer__name {
		font-size: clamp(1.8rem, 3vw, 3rem);
		line-height: 1;
		letter-spacing: 0.03em;
		font-weight: 700;
		color: var(--cor-lilas-footer);
	}

	.site-footer__role,
	.site-footer__crp {
		font-family: var(--fonte-ui);
		font-size: 1.25rem;
		line-height: 1.45;
		color: var(--cor-lilas-footer-secundaria);
	}

	.site-footer__contact {
		display: grid;
		gap: 1.15rem;
		justify-items: start;
		align-content: center;
	}

	.site-footer__item {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		font-family: var(--fonte-ui);
		font-size: 1.2rem;
		color: var(--cor-lilas-principal);
		transition: opacity 0.2s ease;
	}

	.site-footer__item:hover {
		opacity: 0.78;
	}

	.site-footer__icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--cor-lilas-principal);
		flex-shrink: 0;
		transform: scale(1.15);
	}

	.whatsapp-float {
		position: fixed;
		right: 1.4rem;
		bottom: 1.4rem;
		width: 64px;
		height: 64px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 999px;
		background: var(--cor-lilas-escuro);
		color: white;
		box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
		z-index: 1000;
		opacity: 0;
		transform: translateY(20px);
		pointer-events: none;
		transition:
			opacity 0.35s ease,
			transform 0.35s ease,
			box-shadow 0.2s ease;
	}

	.whatsapp-float.visible {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}

	.whatsapp-float:hover {
		transform: translateY(-3px);
		box-shadow: 0 16px 34px rgba(0, 0, 0, 0.22);
	}

	.social__divider {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		align-items: center;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.social__divider-line {
		display: block;
		height: 1px;
		background: rgba(125, 79, 122, 0.3);
	}

	.social__divider-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 34px;
		height: 34px;
		border-radius: 999px;
		background: var(--cor-lilas-principal);
		color: #fff;
		box-shadow: 0 5px 14px rgba(122, 90, 136, 0.16);
	}

	.social__title {
		margin: 0 0 1.25rem;
		color: var(--cor-lilas-texto);
		font-size: clamp(2.2rem, 4.5vw, 4.2rem);
	}

	.social__icon-link {
		display: inline-flex;
		margin-bottom: 2rem;
	}

	.social__icon-circle {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 68px;
