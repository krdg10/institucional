---
import BotaoAcao from "../compartilhados/BotaoAcao.astro";
import ContainerSecao from "../compartilhados/ContainerSecao.astro";
import type {
	ContatosLandingPage,
	DadosApresentacao,
} from "../../tipos/landing-page";

interface Props {
	dadosApresentacao: DadosApresentacao;
	contatos: ContatosLandingPage;
}

const { dadosApresentacao, contatos } = Astro.props;
---

<section class="panel panel--hero" id="inicio">
	<ContainerSecao centralizado>
		<p class="hero__symbol reveal-up reveal-delay-1">Ψ</p>

		<h1
			class="hero__titulo reveal-up reveal-delay-2 cor-hero title-seasons"
		>
			<span class="hero__profissao">
				{dadosApresentacao.profissao}
			</span>

			<span class="hero__nome">
				{dadosApresentacao.nome}
			</span>
		</h1>
		<p class="hero__meta reveal-up reveal-delay-3 font-livvic">
			{dadosApresentacao.crp}
		</p>

		<BotaoAcao
			href={contatos.linkWhatsapp}
			classe="reveal-up reveal-delay-4"
		>
			Agende sua sessão
		</BotaoAcao>

		<p class="hero__tagline reveal-up reveal-delay-5">
			{dadosApresentacao.chamada}
		</p>
	</ContainerSecao>
</section>
