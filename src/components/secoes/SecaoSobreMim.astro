---
import ContainerSecao from "../compartilhados/ContainerSecao.astro";
import type { DadosApresentacao } from "../../tipos/landing-page";

interface Props {
	dadosApresentacao: DadosApresentacao;
}

const { dadosApresentacao } = Astro.props;
---

<section class="panel panel--purple" id="sobre-mim">
	<ContainerSecao split>
		<figure class="photo-wrapper reveal-up reveal-delay-1">
			<img
				class="photo-placeholder"
				src="/me.jpg"
				alt="Psicóloga Débora Fernandes, profissional de psicologia clínica."
				loading="lazy"
			/>
			<figcaption class="caption-oculta">
				Foto de apresentação da psicóloga Débora Fernandes.
			</figcaption>
		</figure>

		<div class="panel__content">
			<p class="reveal-up reveal-delay-1">Olá, meu nome é</p>

			<h2 class="titulo-grande reveal-up reveal-delay-1">
				{dadosApresentacao.tituloSecao}
			</h2>

			{
				dadosApresentacao.textos.map((texto, indice) => (
					<p
						class={`reveal-up reveal-delay-${indice + 2} font-livvic text-align-justify`}
					>
						{texto}
					</p>
				))
			}
		</div>
	</ContainerSecao>
</section>
