---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Débora Fernandes | Psicóloga Clínica",
	description = "Terapia on-line com acolhimento, ética e compromisso com a sua história. Agende sua sessão via WhatsApp.",
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.png" />
		<link rel="icon" href="/favicon.png" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
